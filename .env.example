# Use Claude CLI (subscription) instead of API
# Set to "true" for CLI (default), "false" for API
USE_CLAUDE_CLI=true

# Anthropic API key - only needed if USE_CLAUDE_CLI=false
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# CoinGecko API key (optional - free tier works but has rate limits)
# Get a key at https://www.coingecko.com/en/api/pricing
# COINGECKO_API_KEY=CG-xxxxx
